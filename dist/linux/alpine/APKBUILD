# Maintainer: Devin Little <devinlittlee@gmail.com>
pkgname=dln-git
_pkgname="${pkgname%-git}"
pkgver=0.0.1_git20260616
pkgrel=1
pkgdesc="Bundle of the dlncli and dln-ui"
url="https://git.home.devinlittle.net/devin/devinlittle-net.git"
arch="x86_64 aarch64"
license="AGPL-3.0-only"
makedepends="cargo git pandoc"
checkdepends="cargo"
provides="dlncli=$pkgver-r$pkgrel dln-ui=$pkgver-r$pkgrel"
conflicts="dlncli dln-ui"
source="$_pkgname::git+$url#branch=master"
options="!strip"

prepare() {
	cd "$srcdir/$_pkgname"
	cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
	cd "$srcdir/$_pkgname"

	export CARGO_TARGET_DIR=target
	cargo build --frozen --release --bin dln-cli
	cargo build --frozen --release --bin dln-ui

	# Build man pages
	mkdir -p target/man
	for manpage in dlncli dln-ui; do
		pandoc --standalone -f markdown -t man "dist/man/${manpage}.md" > "target/man/${manpage}.1"
	done
}

check() {
	cd "$srcdir/$_pkgname"
	export CARGO_TARGET_DIR=target
	cargo test --frozen --release --bin dln-cli
	cargo test --frozen --release --bin dln-ui
}

package() {
	cd "$srcdir/$_pkgname"

	# Install binaries
	install -Dm755 "target/release/dln-cli" "$pkgdir/usr/bin/dlncli"
	install -Dm755 "target/release/dln-ui" "$pkgdir/usr/bin/dln-ui"

	# Install desktop and metadata files
	install -Dm644 "dist/linux/dln.desktop" "$pkgdir/usr/share/applications/dln.desktop"
	install -Dm644 "dist/linux/net.devinlittle.dln.metadata.xml" "$pkgdir/usr/share/metainfo/net.devinlittle.dln.metadata.xml"

	# Install shell completions
	install -Dm644 "apps/dln-cli/completions/zsh/_dln-cli" "$pkgdir/usr/share/zsh/site-functions/_dlncli"
	install -Dm644 "apps/dln-cli/completions/fish/dln-cli.fish" "$pkgdir/usr/share/fish/vendor_completions.d/dlncli.fish"
	install -Dm644 "apps/dln-cli/completions/bash/dln-cli" "$pkgdir/usr/share/bash-completion/completions/dlncli"

	# Install man pages
	install -Dm644 target/man/*.1 -t "$pkgdir/usr/share/man/man1/"

	# Install license
	install -Dm644 "apps/core/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}

