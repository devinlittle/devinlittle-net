{
  "app-id": "net.devinlittle.dln",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "24.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "dln-wrapper",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "env": {
      "RUST_BACKTRACE": "1"
    }
  },
  "finish-args": [
    "--socket=wayland",
    "--socket=x11",
    "--device=dri",
    "--fallback-x11"
  ],
  "modules": [
    {
      "name": "dln",
      "buildsystem": "simple",
      "sources": [
        {
          "type": "git",
          "url": "https://git.home.devinlittle.net/devin/devinlittle-net.git",
          "branch": "master"
        },
        "cargo-sources.json"
      ],
      "build-commands": [
        "cargo build --frozen --release --bin dln-cli",
        "cargo build --frozen --release --bin dln-ui",
        "install -Dm755 target/release/dln-cli /app/bin/dlncli",
        "install -Dm755 target/release/dln-ui /app/bin/dln-ui",
        "install -Dm755 dist/linux/flatpak/dln-wrapper /app/bin/dln-wrapper",
        "install -Dm644 dist/linux/dln.desktop /app/share/applications/net.devinlittle.dln.desktop",
        "install -Dm644 dist/linux/net.devinlittle.dln.metadata.xml /app/share/metainfo/net.devinlittle.dln.metadata.xml"
      ]
    }
  ]
}
