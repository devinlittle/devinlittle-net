# builds for macos using zigbuild and linking with zig
build-macos: ensure-packaging-dir ensure-qt-managed ensure-mac-sdk
    @echo "Building macOS cli"
    cargo zigbuild --target aarch64-apple-darwin --release -p dln-cli

    @echo "Building macOS ui"
    echo "aarch64-apple-darwin" > ../scripts/.comp_target_local
    QMAKE={{qmake_wrapper}} \
      cargo xwin build --target aarch64-apple-darwin --release -p dln-ui

package-macos:
  @echo "Packing .App for macOS"
  ../dist/macos/build-macos.sh

package-all: package-linux package-macos build-windows
    @echo "All packages built with soooo much love!"

clean:
    cargo clean

clippy:
    cargo clippy --all-targets --all-features -- -D warnings

test:
    cargo test --all-features

doctor:
    @echo "Checking prerequisites..."
    command -v zig >/dev/null && echo "zig = yes" || echo "zig = no"
    command -v just >/dev/null && echo "just = yes" || echo "just = no "
    cargo --version
    @echo "Run 'just build' to test basic build"

bump-version:
    @echo "TODO: Implement version bumping"

release-dry:
    @echo "Dry run release for version {{version}}"

help:
    @just --list
