# builds for windows using cargo-xwin
build-windows: ensure-packaging-dir ensure-qt-managed
    @echo "Building x86_64 cli"
    cargo xwin build --target x86_64-pc-windows-msvc --release -p dln-cli

    @echo "Building x86_64 ui"
    echo "x86_64-pc-windows-msvc" > ../scripts/.comp_target_local
    QMAKE={{qmake_wrapper}} \
      cargo xwin build --target x86_64-pc-windows-msvc --release -p dln-ui

    cp "{{target_dir}}/x86_64-pc-windows-msvc/release/dln-ui.exe" "{{packaging_dir}}"

