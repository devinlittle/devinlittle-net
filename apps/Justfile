#    bash packaging/scripts/void-helper.sh setup

void-build: ensure-packaging-dir
#    bash packaging/scripts/void-helper.sh build

void-all: ensure-packaging-dir void-setup void-build

package-appimage: ensure-packaging-dir
    @echo "→ Building AppImage..."
    mkdir -p {{packaging_dir}}/appimage

package-flatpak: ensure-packaging-dir
    @echo "→ Building Flatpak..."
#    flatpak-builder --repo={{packaging_dir}}/flatpak/repo ...

